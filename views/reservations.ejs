<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex">
  <meta name="robots" content="nofollow">
  <meta name="author" content="Kevin Marlin">
  <meta name="description" content="Application de gestion des réservations de catways du port de Russell">
  <title>Document</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>
  <header class="bg-dark text-light mb-4 py-4">
    <nav class="navbar navbar-dark">
      <div class="container">
        <h1 class="navbar-brand mb-0">Port de plaisance de Russell</h1>
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/dashboard">Retour</a>
          </li>
        </ul>
      </div>
    </nav>
  </header>

  <main class="container">
    <div class="mb-2">
      <h2>Réservations</h2>
      <p>Selectionner un catway</p>
      <select class="me-2" name="catwayNumberSelect" id="catwaySelect">

      </select>
      <button class="btn btn-primary" id="loadReservations">Charger</button>
    </div>


    <p><a class="newResa-js" href="#"></a></p>

    <!-- Formulaire création de réservation -->
    <div class="newResaCard col-8 mx-auto" hidden >
      <div class="card mb-4 ">
        <div class="card-header"></div>
        <div class="card-body p-4">
          <form id="newResaForm" action="#" >
            <input type="hidden" name="catwayNumber" id="newCatwayNumber">
            <div class="row row-cols-2">
              
              <div class="col mb-3">
                <label for="newClientName">Client</label>
                <input class="form-control" type="text" name="clientName" id="newClientName" required>
              </div>
              <div class="col mb-3">
                <label for="newBoatName">Bateau</label>
                <input class="form-control" type="text" name="boatName" id="newBoatName" required>
              </div>
            </div>
            <div class="row row-cols-2">
              <div class="col mb-3">
                <label for="newStartDate">Entrée</label>
                <input class="form-control" type="date" name="startDate" id="newStartDate" required>
              </div>
              <div class="col mb-3">
                <label for="newEndDate">Entrée</label>
                <input class="form-control" type="date" name="endDate" id="newEndDate" required>
              </div>
            </div>
            <input class="btn btn-primary me-2" type="submit" value="Ajouter">
          </form>
        </div>
      </div>
    </div>  

    <p class="info-newResa text-danger"></p>



    <div class="row">

      <!-- Tableau des reservations -->
      <div class="col-12 col-md-7">
        <p id="info-resa" class="text-danger"></p>
        <table class="table table-hover caption-top" hidden>
          <caption>Liste des réservations</caption>
          <thead class="table-dark">
            <tr>
              <th>Client</th>
              <th>Bateau</th>
              <th>Début</th>
              <th>Fin</th>
            </tr>
          </thead>
          <tbody id="reservationsTable"></tbody>
        </table>
      </div>

      <!-- Information reservation -->
      <div class="col-12 col-md-5 mt-md-5">
        <div class="resaCard card sticky-md-top" hidden>
          
          <div class="card-body p-4">
            <form id="resaForm" action="#">
              <input type="hidden" name="_id" id="reservationId">
              <!-- <input type="hidden" name="catwayNumber" id="catwayResaNumber"> -->
              <div class="mb-4">
                <label for="clientNameUpdate" class="form-label">Client</label>
                <input type="text" name="clientName" id="clientNameUpdate" class="form-control">
              </div>
              <div class="mb-4">
                <label for="boatNameUpdate" class="form-label">Bateau</label>
                <input type="text" name="boatName" id="boatNameUpdate" class="form-control">
              </div>
              <div class="row row-cols-2">
                <div class="col mb-4">
                  <label for="startDateUpdate" class="form-label">Entrée</label>
                  <input type="date" name="startDate" id="startDateUpdate" class="form-control">
                </div>
                <div class="col mb-4">
                  <label for="endDateUpdate" class="form-label">Sortie</label>
                  <input type="date" name="endDate" id="endDateUpdate" class="form-control">
                </div>
              </div>

              <input class="btn btn-primary me-2" type="submit" value="Modifier">
              <input class="btn btn-danger" type="button" id="resaFormDelete" value="Supprimer">
            </form>
            <p class="resaCard-info"></p>
          </div>
        </div>
      </div>

    </div>






  </main>
  

  <script src="javascripts/reservations.js" type="text/javascript"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
