<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Réservations</title>
  <!-- <link rel="stylesheet" href="/css/style.css"> -->
</head>
<body>

  <header>
    <h1>Gestion des réservations</h1>
  </header>

  <section>
    <h2>Catways</h2>
    <p id="catways-info"></p>
    <select id="catwaySelect"></select>
    <button id="loadReservations">Charger</button>
  </section>

  <section>
    <h2>Réservations</h2>
    <table>
      <thead>
        <tr>
          <th>Client</th>
          <th>Bateau</th>
          <th>Début</th>
          <th>Fin</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="reservationsTable"></tbody>
    </table>
  </section>

  <section>
    <h2>Ajouter / Modifier</h2>
    <form id="reservationForm">
      <input type="hidden" id="reservationId">

      <input type="text" id="clientName" placeholder="Client" required>
      <input type="text" id="boatName" placeholder="Bateau" required>
      <input type="date" id="startDate" required>
      <input type="date" id="endDate" required>

      <button type="submit">Enregistrer</button>
    </form>
  </section>

  <script src="javascripts/reservations.js" type="text/javascript"></script>
</body>
</html>