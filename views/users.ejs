<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="stylesheets/users.css">
    <title>Port de Russell - Utilisateurs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>
  <header class="bg-dark text-light mb-4 py-4">
    <nav class="navbar navbar-dark">
      <div class="container">
        <h1 class="navbar-brand mb-0">Port de plaisance de Russell</h1>
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/dashboard">Retour</a>
          </li>
        </ul>
      </div>
    </nav>
  </header>

  <main class="container">
    <h2>Utilisateurs</h2>
    <p class="mb-4"><a id="newUserBtn" href="#">Ajouter un utilisateur</a></p>

    <div class="newUserForm col-8 mx-auto" hidden >
      <div class="card mb-4 p-4">
        <div class="card-body">
          <form id="createUserForm" action="/users/add" method="PUT" >
              <div>
                <label class="form-label" for="username">Nom de l'utilisateur :</label>
                <input class="form-control" type="text" name="username" id="username" >
                <p>Le nom ne doit pas contenir de nombre.</p>
              </div>
              <div>
                <label class="form-label" for="email">Adresse e-mail :</label>
                <input class="form-control" type="email" name="email" id="email" required>
                <p>Renseigner une addresse valide de l'organisation.</p>
              </div>
              <div>
                <label class="form-label" for="password">Mot de passe :</label>
                <input class="form-control" type="password" name="password" id="password" >
                <p>Le mot de passe doit remplir les conditions suivantes :</p>
                <ul>
                  <li>minimum 8 caractères</li>
                  <li>contenir minimum 1 caractère spécial [ #?!@$%^&*- ]</li>
                  <li>contenir minimum 1 lettre majuscule</li>
                  <li>contenir minimum 1 chiffre</li>
                </ul>
              </div>
              <input class="btn btn-primary me-2" type="submit" value="Ajouter">
          </form>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-12 col-md-7 mb-4">
        <% if (users.length === 0) { %>
          <p>Aucune utilisateur enregistrée.</p>
        <% } else { %>
          <table class="table table-hover caption-top">
            <caption>Liste des utilisateurs</caption>
            <thead class="table-dark">
              <tr>
                <th>Nom</th>
                <th>e-mail</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(user => { %>
                <tr>
                  <td><%= user.username %></td>
                  <td><%= user.email %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>

      <div class="col-12 col-md-5 mt-md-5">
        <div class="userForm card sticky-md-top" aria-hidden="true" hidden >
          <div class="card-header">
            <h3>Compte : <span></span></h3>
          </div>
          <div class="card-body p-4">
            <form id="userForm" action="#">
              <div class="mb-4">
                <label class="form-label" for="username">Nom</label>
                <input type="text" class="form-control" name="username" id="data-username">
              </div>

              <div class="mb-4">
                <label class="form-label" for="password">Mot de passe</label>
                <input class="form-control mb-2" type="password" name="password" id="data-password">
                <p>Le mot de passe doit remplir les conditions suivantes :</p>
                <ul>
                  <li>minimum 8 caractères</li>
                  <li>contenir minimum 1 caractère spécial [ #?!@$%^&*- ]</li>
                  <li>contenir minimum 1 lettre majuscule</li>
                  <li>contenir minimum 1 chiffre</li>
                </ul>
              </div>

              <input class="btn btn-primary me-2" type="submit" value="Modifier">
              <input class="btn btn-danger" type="button" value="Supprimer">
            </form>
            <p id="info-userForm"></p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script src="javascripts/users.js" type="text/javascript"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
