<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Port de Russell - Utilisateurs</title>
</head>
<body>
    <header>
        <nav>
            <a href="/dashboard">Retour</a>
        </nav>
    </header>
    <main>
        <h1>Utilisateurs</h1>

        <% if (users.length === 0) { %>
          <p>Aucune utilisateur enregistrée.</p>
        <% } else { %>
          <p>Liste des utilisateurs</p>
          <table border="1" cellpadding="5">
            <thead>
              <tr>
                <th>Nom</th>
                <th>e-mail</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(user => { %>
                <tr>
                  <td><%= user.username %></td>
                  <td><%= user.email %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>

        <% } %>
    </main>
    
</body>
</html>