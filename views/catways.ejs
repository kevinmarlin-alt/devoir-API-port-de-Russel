<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Port de Russell - Cateways</title>
    <link rel="stylesheet" href="stylesheets/catways.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>
    <header class="bg-dark text-light mb-4 py-4">
        <nav class="navbar navbar-dark">
          <div class="container">
            <h1 class="navbar-brand mb-0">Port de plaisance de Russell</h1>
            <ul class="navbar-nav">
              <li class="nav-item">
                <a class="nav-link" href="/dashboard">Retour</a>
              </li>
            </ul>
          </div>
        </nav>
      </header>

      <main class="container">
        <h2>Catways</h2>
        <a class="newCatway-js" href="#">Ajouter un nouveau Catway</a>
        <p id="info-catwaysForm"></p>

        <!-- Formulaire de création de catway -->
        <div class="newCatwayForm col-8 mx-auto" aria-hidden="true" hidden>
           <div class="card mb-4 p-4">
             <div class="card-body">
                <form id="createCatwayForm" action="#">
                  <div class="row row-cols-2">
                    <div class="mb-3 col">
                      <label for="createCatwayNumber" class="form-label">Numéro</label>
                      <input type="number" class="form-control" name="catwayNumber" id="createCatwayNumber" min="0">
                    </div>
                    <div class="mb-3 col">
                      <label for="createCatwayType" class="form-label">Type</label>
                      <select class="form-control" name="catwayType" id="createCatwayType">
                        <option value="short">short</option>
                        <option value="long">long</option>
                      </select>
                    </div>
                  </div>
                  <div class="mb-3">
                    <label for="catwayState" class="form-label">Description</label>
                    <input type="text" class="form-control" name="catwayState" id="catwayState" >
                  </div>
                  <input class="btn btn-primary me-2" type="submit" value="Ajouter">
                </form>
             </div>
           </div>
        </div>
  
        <div class="row">
          <div class="col-12 col-md-7">

            <!-- Tableau de catways -->
            <% if (catways.length === 0) { %>
              <p class="text-danger">Aucun catway enregistré.</p>
            <% } else { %>
          
              <table class="table table-hover caption-top">
                <caption>Liste détaillée des catways</caption>
                <thead class="table-dark">
                  <tr>
                    <th>No</th>
                    <th>Type</th>
                    <th>Description</th>
                  </tr>
                </thead>
                <tbody>
                  <% catways.forEach(catway => { %>
                    <tr>
                      <td><%= catway.catwayNumber %></td>
                      <td><%= catway.catwayType %></td>
                      <td><%= catway.catwayState %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </div>
          <div class="col-12 col-md-5 mt-md-5">

            <!-- Information catway -->
            <div class="catwayForm card sticky-md-top" hidden>
              <div class="card-header p-4">
                <h3>Catway n° <span>xxx</span></h3>
              </div>
              <div class="card-body p-4">
                <form id="catwaysForm" action="#">
                  <div class="mb-4">
                    <label for="catwayStateUpdate" class="form-label">Description</label>
                    <textarea name="catwayState" class="form-control" id="catwayStateUpdate" rows="4" ></textarea>
                  </div>
                  <input class="btn btn-primary me-2" type="submit" value="Modifier">
                  <input class="btn btn-danger" type="button" value="Supprimer">
                </form>

              </div>
            </div>
          </div>
        </div>

     

      
    </main>
    <script src="javascripts/catways.js" type="text/javascript"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

</body>
</html>