<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Port de Russell - Cateways</title>
    <link rel="stylesheet" href="stylesheets/catways.css">
</head>
<body>
    <header>
        <nav>
          <a href="/dashboard">Retour</a>
        </nav>
        <h1>Catways</h1>
    </header>
    <main>

      <form id="createCatwayForm" action="#"  >
        <fieldset>
          <legend>Formulaire d'ajout de nouveau catway</legend>
          <div>
            <label for="createCatwayNumber">Numéro du catway :</label>
            <input 
              type="number" 
              name="catwayNumber" 
              id="createCatwayNumber" 
              min="0">
          </div>
          <div>
            <label for="createCatwayType">Type de catway :</label>
            <select name="catwayType" id="createCatwayType">
              <option value="short">short</option>
              <option value="long">long</option>
            </select>
          </div>
          <div>
            <label for="createCatwayState">Etat du cateway :</label>
            <input type="text" name="catwayState" id="createCatwayState" >
          </div>
          <input type="submit" value="Ajouter">
        </fieldset>
      </form>

      <form id="catwaysForm" action="#">
          <fieldset>
            <legend>Formulaire de modification</legend>
            <h2>Informations du catway n° <span>xxx</span></h2>
            <div>
              <label for="catwayType">Type de catway : </label>
              <select name="catwayType" id="catwayType">
                <option value="short">short</option>
                <option value="long">long</option>
              </select>
            </div>
            <div>
              <label for="catwayState">Etat : </label>
              <input type="text" name="catwayState" id="catwayState">
            </div>
            <input type="submit" value="Modifier">
            <input type="button" value="Supprimer">
          </fieldset>
        </form>
        <p id="info-catwaysForm"></p>

        <% if (catways.length === 0) { %>
          <p>Aucune catway enregistrée.</p>
        <% } else { %>
          <p>Liste des catways</p>
          <table border="1" cellpadding="5">
            <thead>
              <tr>
                <th>No</th>
                <th>Type</th>
                <th>Description</th>
              </tr>
            </thead>
            <tbody>
              <% catways.forEach(catway => { %>
                <tr>
                  <td><%= catway.catwayNumber %></td>
                  <td><%= catway.catwayType %></td>
                  <td><%= catway.catwayState %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>

        <% } %>
    </main>
    <script src="javascripts/catways.js" type="text/javascript"></script>
</body>
</html>